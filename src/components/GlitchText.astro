---
interface Props {
  text: string;
  as?: string;
  class?: string;
}

const { text, as: Tag = 'span', class: cls = '' } = Astro.props;
---
<Tag class={`glitch relative inline-block ${cls}`} data-text={text}>
  <span class="block">{text}</span>
</Tag>

<style>
  .glitch {
    position: relative;
  }
  .glitch::before,
  .glitch::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  .glitch::before {
    animation: glitch-1 2.5s infinite steps(2, jump-none);
    color: var(--crimson);
    z-index: -1;
    mix-blend-mode: screen;
  }
  .glitch::after {
    animation: glitch-2 3s infinite steps(2, jump-none);
    color: var(--gold);
    z-index: -2;
    mix-blend-mode: screen;
  }

  @keyframes glitch-1 {
    0%, 90%, 100% { transform: translate(0, 0); opacity: 0; }
    92% { transform: translate(-3px, 2px); opacity: 0.8; }
    94% { transform: translate(3px, -1px); opacity: 0.6; }
    96% { transform: translate(-2px, -2px); opacity: 0.7; }
  }
  @keyframes glitch-2 {
    0%, 85%, 100% { transform: translate(0, 0); opacity: 0; }
    87% { transform: translate(2px, 1px); opacity: 0.5; }
    89% { transform: translate(-2px, 2px); opacity: 0.7; }
    91% { transform: translate(1px, -2px); opacity: 0.6; }
  }

  @media (prefers-reduced-motion: reduce) {
    .glitch::before, .glitch::after { display: none; }
  }
</style>
