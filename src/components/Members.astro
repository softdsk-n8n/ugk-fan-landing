---
const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
const members = [
  {
    nick: 'Pimp C',
    realName: 'Chad Butler',
    dates: '1973 — 2007',
    photo: `${base}images/members/pimp-c.webp`,
    accent: 'gold',
    bio: 'Продюсер, вокалист, идеолог звука UGK. Его биты, построенные на funk-семплах и медленных басах, стали ДНК хьюстонского саунда. Острый язык, бескомпромиссный. Умер 4 декабря 2007-го в Лос-Анджелесе.',
    legacy: 'Pimp C дал южному хип-хопу голос — не просто акцент, а мировоззрение.'
  },
  {
    nick: 'Bun B',
    realName: 'Bernard Freeman',
    dates: '1973 — ',
    photo: 'https://placehold.co/800x1000/0A0A0A/FFD700/webp?text=Bun+B%0A%28replace+with%0Areal+photo%29',
    accent: 'crimson',
    bio: 'Главный лирический мотор UGK. После ухода Pimp C — один из самых уважаемых ветеранов хип-хопа. Преподаёт курс по религии и рэпу в Rice University. Продолжает соло-карьеру и защищает наследие UGK.',
    legacy: 'Bun B — живая институция. Пока он читает, история UGK продолжается.'
  }
];
---
<section id="members" class="relative py-24 md:py-40 bg-ink">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="font-mono text-xs md:text-sm text-gold uppercase tracking-wider mb-6">
      / 02 — ДУЭТ
    </div>
    <h2 class="font-heading text-5xl md:text-7xl uppercase tracking-brutal text-parchment mb-12 md:mb-20">
      Два голоса.<br />
      <span class="text-crimson">Один Port Arthur.</span>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
      {members.map((m, i) => (
        <article class={`group relative bg-ink-2 brutal-border ${m.accent === 'crimson' ? 'md:mt-20' : ''}`}>
          <div class="aspect-[4/5] overflow-hidden relative bg-ink">
            <img
              src={m.photo}
              alt={`${m.nick} (${m.realName})`}
              width={800}
              height={1000}
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding="async"
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/40 to-transparent pointer-events-none"></div>
          </div>

          <div class="p-6 md:p-10">
            <div class="flex items-baseline justify-between gap-4 mb-4">
              <h3 class={`font-display text-5xl md:text-7xl leading-none ${m.accent === 'gold' ? 'text-gold' : 'text-crimson'}`}>
                {m.nick}
              </h3>
              <span class="font-mono text-xs text-parchment/50 whitespace-nowrap">{m.dates}</span>
            </div>
            <div class="font-mono text-sm text-parchment/70 mb-6">{m.realName}</div>
            <p class="text-base md:text-lg font-body text-parchment/90 leading-relaxed mb-6">
              {m.bio}
            </p>
            <blockquote class="border-l-4 border-gold pl-6 italic text-parchment/80 font-body">
              {m.legacy}
            </blockquote>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
