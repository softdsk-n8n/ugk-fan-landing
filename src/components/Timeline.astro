---
import timeline from '../data/timeline.json';
---
<section id="timeline" class="relative py-24 md:py-40 bg-ink-2 scanlines">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="font-mono text-xs md:text-sm text-gold uppercase tracking-wider mb-6">
      / 05 — ТАЙМЛАЙН
    </div>
    <h2 class="font-heading text-5xl md:text-7xl uppercase tracking-brutal text-parchment mb-4">
      От 1973 <br />
      <span class="text-crimson">до сейчас.</span>
    </h2>
    <p class="font-body text-lg text-parchment/70 max-w-2xl mb-12 md:mb-16">
      Пятнадцать точек, в которых меняется вся траектория.
    </p>
  </div>

  <div class="relative">
    <div class="timeline-scroll overflow-x-auto overflow-y-hidden scroll-smooth snap-x snap-mandatory">
      <div class="flex gap-6 md:gap-8 px-6 md:px-10 pb-10 min-w-max">
        {timeline.map((t, i) => (
          <article class="snap-start flex-shrink-0 w-72 md:w-96 bg-ink brutal-border p-6 md:p-8 relative">
            <div class="font-display text-6xl md:text-7xl text-gold leading-none mb-4">
              {t.year}
            </div>
            <div class="font-mono text-xs text-parchment/50 mb-4 uppercase tracking-wider">
              / {String(i + 1).padStart(2, '0')} из {timeline.length}
            </div>
            <p class="font-body text-base md:text-lg text-parchment/90 leading-relaxed">
              {t.event}
            </p>
          </article>
        ))}
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 md:px-10 mt-6 font-mono text-xs text-parchment/50 flex items-center gap-4">
      <span aria-hidden="true">←</span>
      <span class="uppercase tracking-wider">Свайп / скролл по горизонтали</span>
      <span aria-hidden="true">→</span>
    </div>
  </div>
</section>

<style>
  .timeline-scroll::-webkit-scrollbar {
    height: 6px;
  }
  .timeline-scroll::-webkit-scrollbar-track {
    background: #0A0A0A;
  }
  .timeline-scroll::-webkit-scrollbar-thumb {
    background: var(--gold);
  }
</style>
