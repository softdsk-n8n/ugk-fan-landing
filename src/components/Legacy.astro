---
import quotes from '../data/quotes.json';
---
<section id="legacy" class="relative py-24 md:py-40 woodgrain">
  <div class="absolute inset-0 bg-ink/70"></div>
  <div class="relative max-w-7xl mx-auto px-6 md:px-10">
    <div class="font-mono text-xs md:text-sm text-gold uppercase tracking-wider mb-6" data-ru-text="/ 06 — НАСЛЕДИЕ" data-en-text="/ 06 — LEGACY">
      / 06 — НАСЛЕДИЕ
    </div>
    <h2 class="font-heading text-5xl md:text-7xl uppercase tracking-brutal text-parchment mb-4">
      <span data-ru-text="Что говорят" data-en-text="What the">Что говорят</span><br />
      <span class="text-gold" data-ru-text="великие." data-en-text="greats say.">великие.</span>
    </h2>
    <p class="font-body text-lg text-parchment/70 max-w-2xl mb-12 md:mb-20" data-ru-text="Когда о UGK говорят Jay-Z, André 3000, Big Boi — дискуссия закрыта." data-en-text="When Jay-Z, André 3000, Big Boi speak on UGK — the discussion is closed.">
      Когда о UGK говорят Jay-Z, André 3000, Big Boi — дискуссия закрыта.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10">
      {quotes.map((q, i) => (
      <figure class={`bg-ink border-l-4 ${i % 2 === 0 ? 'border-gold' : 'border-crimson'} p-8 md:p-10 ${i % 3 === 1 ? 'md:translate-y-8' : ''}`}>
        <blockquote class="font-display text-2xl md:text-4xl lg:text-5xl leading-tight tracking-brutal text-parchment mb-6 lang-quote" data-ru={`"${q.translation}"`} data-en={`"${q.original}"`}>
          "{q.translation}"
        </blockquote>
        <p class="font-mono text-xs md:text-sm text-parchment/50 italic mb-6 border-t border-parchment/10 pt-4 lang-original" data-ru={`«${q.original}»`} data-en="">
          «{q.original}»
        </p>
        <figcaption class="font-heading text-2xl md:text-3xl uppercase tracking-wider">
          <span class={i % 2 === 0 ? 'text-gold' : 'text-crimson'}>{q.author}</span>
          <span class="block font-mono text-xs text-parchment/60 mt-1 normal-case tracking-normal">
            {q.role}
          </span>
        </figcaption>
      </figure>
      ))}
    </div>
  </div>
</section>

<script>
  function updateQuotes() {
    const lang = document.documentElement.getAttribute('lang') || 'ru';
    document.querySelectorAll<HTMLElement>('.lang-quote').forEach((el) => {
      const ru = el.dataset.ru || '';
      const en = el.dataset.en || '';
      el.innerHTML = lang === 'en' ? en : ru;
    });
    document.querySelectorAll<HTMLElement>('.lang-original').forEach((el) => {
      const ru = el.dataset.ru || '';
      const en = el.dataset.en || '';
      el.innerHTML = lang === 'en' ? en : ru;
      el.style.display = lang === 'en' ? 'none' : '';
    });
  }
  updateQuotes();
  const obs = new MutationObserver(updateQuotes);
  obs.observe(document.documentElement, { attributes: true, attributeFilter: ['lang'] });
</script>
