---
import tracks from '../data/tracks.json';
---
<section id="essential-tracks" class="relative py-24 md:py-40 bg-ink">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="font-mono text-xs md:text-sm text-gold uppercase tracking-wider mb-6" data-ru-text="/ 04 — ЭССЕНШИАЛЫ" data-en-text="/ 04 — ESSENTIALS">
      / 04 — ЭССЕНШИАЛЫ
    </div>
    <h2 class="font-heading text-5xl md:text-7xl uppercase tracking-brutal text-parchment mb-4">
      <span data-ru-text="С чего" data-en-text="Where to">С чего</span><br />
      <span class="text-gold" data-ru-text="начать слушать" data-en-text="start listening">начать слушать</span>
    </h2>
    <p class="font-body text-lg text-parchment/70 max-w-2xl mb-12 md:mb-16" data-ru-text="Пять треков — не чтобы понять UGK, а чтобы понять южный хип-хоп вообще." data-en-text="Five tracks — not just to understand UGK, but to understand Southern hip-hop period.">
      Пять треков — не чтобы понять UGK, а чтобы понять южный хип-хоп вообще.
    </p>

    <div class="space-y-10 md:space-y-16">
      {tracks.map((t, i) => (
      <article class="grid grid-cols-1 lg:grid-cols-12 gap-6 md:gap-10 items-start border-t border-parchment/10 pt-8 md:pt-12">
        <div class="lg:col-span-1 font-display text-6xl md:text-7xl text-gold leading-none">
          {String(i + 1).padStart(2, '0')}
        </div>
        <div class="lg:col-span-5">
          <h3 class="font-heading text-3xl md:text-5xl uppercase tracking-brutal text-parchment leading-none mb-3">
            {t.title}
          </h3>
          <div class="font-mono text-xs md:text-sm text-parchment/60 uppercase tracking-wider mb-4">
            {t.album} · {t.year}
          </div>
          <p class="text-base md:text-lg text-parchment/80" data-ru={t.note_ru} data-en={t.note_en}>
            {t.note_ru}
          </p>
        </div>
        <div class="lg:col-span-6">
          <div class="relative aspect-video bg-ink-2 brutal-border-crimson overflow-hidden">
            <iframe
              src={`${t.youtube}?rel=0&modestbranding=1`}
              title={`${t.title} — UGK`}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              referrerpolicy="strict-origin-when-cross-origin"
              class="w-full h-full"
            ></iframe>
          </div>
        </div>
      </article>
      ))}
    </div>

    <p class="mt-16 font-mono text-xs text-parchment/40 text-center uppercase tracking-wider" data-ru-text="Видео встроены через YouTube. Вся музыка — собственность UGK и правообладателей." data-en-text="Videos embedded via YouTube. All music is property of UGK and rights holders.">
      Видео встроены через YouTube. Вся музыка — собственность UGK и правообладателей.
    </p>
  </div>
</section>
